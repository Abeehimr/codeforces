{
  "languages": {
    "Python": {
      "language_servers": ["basedpyright", "!ruff"],
      "format_on_save": "on",
      "formatter": {
        "language_server": {
          "name": "basedpyright"
        }
      }
    }
  },
  "lsp": {
    "basedpyright": {
      "settings": {
        "basedpyright.analysis": {
          "diagnosticMode": "openFilesOnly",
          "typeCheckingMode": "basic"
        }
      }
    }
  }
}