{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Python",
            "type": "shell",
            "command": "python3 ${relativeFile} < input.txt > output.txt",
            "presentation": {
                "reveal": "silent"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "C++",
            "type": "shell",
            "command": "g++ ${relativeFile} -std=c++17 -O0 -g -Wall -Wextra -Wshadow -fsanitize=address,undefined -o ${fileBasenameNoExtension}.out",
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "reveal": "silent"
            }
        },
        {
            "label": "Run C++",
            "type": "shell",
            "command": "./${fileBasenameNoExtension}.out < input.txt > output.txt",
            "dependsOn": "C++",
            "presentation": {
                "reveal": "never"
            },
            "group": {
                "kind": "test",
                "isDefault": true
            }
        }
    ]
}